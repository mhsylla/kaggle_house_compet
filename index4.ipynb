    "train_sizes, train_scores, val_scores = learning_curve(\n",
    "    catboost_model,\n",
    "    df_train,\n",
    "    log_target,\n",
    "    cv=5,\n",
    "    scoring=\"neg_root_mean_squared_error\",\n",
    "    train_sizes=np.linspace(0.1, 1.0, 10),\n",
    "    n_jobs=-1\n",
    ")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 93,
   "id": "cac9d87a",
   "metadata": {},
   "outputs": [
