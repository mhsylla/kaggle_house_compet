    "                 'GarageQual', 'GarageCond', 'PoolQC']\n",
    "\n",
    "for col in ordinal_1:\n",
    "    if 'None' in df[col].value_counts().index:\n",
    "        df[col] = df[col].map({\"None\":0,\"Po\":1,\"Fa\":2,\"TA\":3,\"Gd\":4,\"Ex\":5}).astype('int')\n",
    "    else:\n",
    "        df[col] = df[col].map({\"Po\":1,\"Fa\":2,\"TA\":3,\"Gd\":4,\"Ex\":5}).astype('int')"
   ]
